# NexoraAI Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Redis (Upstash)
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your_upstash_redis_token_here

# LLM APIs
GEMINI_API_KEY=AIzaSy...

# Google APIs (same key works for both if both APIs are enabled in Google Cloud Console)
GOOGLE_SAFE_BROWSING_API_KEY=AIzaSy...
GOOGLE_VISION_API_KEY=AIzaSy...

# Security APIs
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Voice
ELEVENLABS_API_KEY=sk_...

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:19006
