# NexoraAI Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# EXPO_PUBLIC_ prefix makes variables available in the React Native bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
EXPO_PUBLIC_SCANNER_API_URL=https://nexora-scanner.onrender.com
