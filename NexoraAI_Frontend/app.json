{
  "expo": {
    "name": "NexoraAI",
    "slug": "nexoraai",
    "version": "1.0.0",
    "scheme": "nexoraai",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "package": "com.nexoraai.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "nexoraai",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_SMS",
        "android.permission.RECEIVE_SMS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.nexoraai.app"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0a0f1e"
    },
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "extraPermissions": [
              "android.permission.READ_SMS",
              "android.permission.RECEIVE_SMS"
            ]
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "NexoraAI needs camera access to scan suspicious messages.",
          "photosPermission": "NexoraAI needs photo access to scan screenshots for phishing threats."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "33e74d1b-bf3b-409c-805a-122fcdc81e52"
      }
    },
    "owner": "toxicc05"
  }
}
