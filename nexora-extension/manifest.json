{
    "manifest_version": 3,
    "name": "Nexora AI",
    "version": "1.1",
    "description": "Scan emails and SMS messages for phishing attempts using Nexora AI — powered by Supabase and NexoraAI scanner.",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}